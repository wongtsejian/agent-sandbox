# LLM Gateway API key — injected by gateway into requests to host.containers.internal:8000
STX_LLM_GATEWAY_API_KEY=

# GitHub PAT — used by github-pat plugin for HTTPS git auth via gateway
GITHUB_PAT=

# MCP OAuth — used by mcp-oauth plugin
MCP_OAUTH_CLIENT_ID=your-oauth-client-id
MCP_OAUTH_CLIENT_SECRET=your-oauth-client-secret
