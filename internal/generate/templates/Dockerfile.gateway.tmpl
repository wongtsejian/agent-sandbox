FROM {{ .GatewayBuildImage }} AS builder
WORKDIR /src
COPY gateway-src/ .
RUN go mod tidy && go build -o {{ .GatewayBinaryPath }} ./cmd/gateway/

FROM alpine:3.20
RUN apk add --no-cache ca-certificates iptables
COPY --from=builder {{ .GatewayBinaryPath }} /usr/local/bin/gateway
COPY gateway-config.yaml /etc/gateway/config.yaml
{{ if .HasMITM -}}
RUN mkdir -p /shared/certs /etc/gateway/private && chmod 700 /etc/gateway/private
{{ end -}}
COPY gateway-entrypoint.sh /opt/entrypoint.sh
RUN chmod +x /opt/entrypoint.sh
ENTRYPOINT ["/opt/entrypoint.sh"]
