# Gateway configuration (auto-generated)
listen: ":{{.ListenPort}}"
dns_listen: ":{{.DNSPort}}"
{{- if .MITMDomains}}
mitm_domains:
{{- range .MITMDomains}}
  - {{.}}
{{- end}}
{{- end}}
{{- if .Rewriters}}
rewriters:
{{- range .Rewriters}}
  - type: {{.Type}}
{{- if .Domains}}
    domains:
{{- range .Domains}}
      - {{.}}
{{- end}}
{{- end}}
{{- if .EnvVar}}
    env_var: {{.EnvVar}}
{{- end}}
{{- if .Header}}
    header: "{{.Header}}"
{{- end}}
{{- if .ValueFormat}}
    value_format: "{{.ValueFormat}}"
{{- end}}
{{- if .TokenFile}}
    token_file: "{{.TokenFile}}"
{{- end}}
{{- end}}
{{- end}}
{{- if .PortForwards}}
port_forwards:
{{- range .PortForwards}}
  - listen: ":{{.HostPort}}"
    target: "{{.AgentName}}:{{.ContainerPort}}"
{{- end}}
{{- end}}
