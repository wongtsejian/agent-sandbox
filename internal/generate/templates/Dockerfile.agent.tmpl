{{ if .ChannelManager -}}
FROM {{ .CMBuildImage }} AS channel-manager-build
WORKDIR /src
COPY channel-manager-src/package.json channel-manager-src/tsconfig.json ./
RUN {{ .CMInstallCmd }}
COPY channel-manager-src/src/ ./src/
RUN {{ .CMBuildCmd }}

{{ end -}}
FROM {{ .BaseImage }}
RUN apt-get update && apt-get install -y --no-install-recommends iproute2 iptables ca-certificates && rm -rf /var/lib/apt/lists/*
RUN useradd -m -s /bin/bash {{ .User }}
{{ if .VolumePaths -}}
RUN mkdir -p {{ join " " .VolumePaths }} && chown -R {{ .User }}:{{ .User }} {{ join " " .VolumePaths }}
{{ end -}}
{{ range .Install -}}
RUN {{ . }}
{{ end -}}
{{ range .FeatureCmds -}}
RUN {{ . }}
{{ end -}}
{{ if .ChannelManager -}}
# Install channel-manager
COPY --from=channel-manager-build {{ .CMDistDir }}/ /opt/channel-manager/dist/
COPY --from=channel-manager-build /src/node_modules/ /opt/channel-manager/node_modules/
COPY --from=channel-manager-build /src/package.json /opt/channel-manager/package.json
COPY channel-manager-config.json /opt/channel-manager/config.json
{{ end -}}
{{ if .HasHomeOverride -}}
COPY home-override/ /opt/home-override/

{{ end -}}
{{ if .HasHooks -}}
COPY hooks/ /opt/hooks/
RUN chmod +x /opt/hooks/*

{{ end -}}
COPY entrypoint.sh /opt/entrypoint.sh
RUN chmod +x /opt/entrypoint.sh
WORKDIR /home/{{ .User }}
ENTRYPOINT ["/opt/entrypoint.sh"]
