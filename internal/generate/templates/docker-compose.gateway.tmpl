services:
  {{ .GatewayName }}:
    build:
      context: .
      dockerfile: Dockerfile.gateway
    networks:
      internal:
      default:
    cap_add:
      - NET_ADMIN
    sysctls:
      - net.ipv4.ip_forward=1
    environment:
      - LOG_LEVEL={{ .LogLevel }}
{{- range .EnvVars }}
      - {{ . }}=${{"{"}}{{ . }}{{"}"}}
{{- end }}
{{- if .Ports }}
    ports:
{{- range .Ports }}
      - {{ quote . }}
{{- end }}
{{- end }}
    restart: unless-stopped
{{- if .HasMITM }}
    volumes:
      - shared-certs:/shared/certs
    healthcheck:
      test: ["CMD", "test", "-f", "{{ .GatewayCertDir }}/ca.crt"]
      interval: 1s
      timeout: 1s
      retries: 10
      start_period: 2s
{{- end }}
  {{ .AgentName }}:
    build:
      context: .
      dockerfile: Dockerfile.agent
    networks:
      internal:
    cap_add:
      - NET_ADMIN
    sysctls:
      - net.ipv4.conf.all.route_localnet=1
    environment:
      - LOG_LEVEL={{ .LogLevel }}
      - GATEWAY_HOST={{ .GatewayName }}
{{- range .AgentEnv }}
      - {{ . }}
{{- end }}
{{- if .HasMITM }}
    depends_on:
      {{ .GatewayName }}:
        condition: service_healthy
{{- else }}
    depends_on:
      - {{ .GatewayName }}
{{- end }}
{{- if .Volumes }}
    volumes:
{{- range .Volumes }}
      - {{ . }}
{{- end }}
{{- end }}
    restart: unless-stopped

networks:
  internal:
    internal: true
{{- if .NamedVolumes }}

volumes:
{{- range .NamedVolumes }}
  {{ . }}:
{{- end }}
{{- end }}
