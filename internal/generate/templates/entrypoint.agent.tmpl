#!/bin/bash
set -e
{{ if .HasGateway }}
echo "entrypoint: resolving gateway..."
GATEWAY_IP=$(getent hosts $GATEWAY_HOST | awk '{print $1}')
if [ -z "$GATEWAY_IP" ]; then
  echo "entrypoint: ERROR — cannot resolve $GATEWAY_HOST" >&2
  exit 1
fi
echo "entrypoint: gateway at $GATEWAY_IP"

echo "entrypoint: switching DNS to gateway..."
echo "nameserver $GATEWAY_IP" > /etc/resolv.conf

echo "entrypoint: setting default route via gateway..."
ip route replace default via $GATEWAY_IP

echo "entrypoint: redirecting traffic to gateway proxy..."
iptables -t nat -A OUTPUT -p tcp --dport 443 -j DNAT --to-destination $GATEWAY_IP:{{ .GatewayListenPort }}
{{- range .HTTPPorts }}
iptables -t nat -A OUTPUT -p tcp --dport {{ . }} -j DNAT --to-destination $GATEWAY_IP:{{ $.GatewayListenPort }}
{{- end }}
{{ range .Ports }}
iptables -t nat -A PREROUTING -p tcp --dport {{ .ContainerPort }} -j DNAT --to-destination 127.0.0.1:{{ .ContainerPort }}
{{ end }}{{ end }}{{ if .HasMITM }}
# Wait for sandbox CA certificate from gateway (shared volume)
echo "entrypoint: waiting for sandbox CA certificate..."
timeout=30
elapsed=0
while [ ! -f {{ .CACertPath }} ]; do
  sleep 0.1
  elapsed=$((elapsed + 1))
  if [ "$elapsed" -ge "$((timeout * 10))" ]; then
    echo "entrypoint: ERROR — CA certificate not available after ${timeout}s" >&2
    exit 1
  fi
done
update-ca-certificates 2>/dev/null
export NODE_EXTRA_CA_CERTS={{ .CACertPath }}
echo "entrypoint: CA certificate trusted"
{{ end }}{{ if .HasHomeOverride }}
echo "entrypoint: applying home override..."
if [ -d /opt/home-override ]; then
  cp -rT /opt/home-override /home/{{ .User }}
  chown -R {{ .User }}:{{ .User }} /home/{{ .User }}
fi
{{ end }}
exec su -c '{{ .UserCommand }}' {{ .User }}
